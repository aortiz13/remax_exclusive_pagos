{
  "manifest_version": 3,
  "name": "RE/MAX Meeting Recorder",
  "version": "1.0.0",
  "description": "Graba reuniones de reclutamiento, transcribe y extrae datos automáticamente para el CRM RE/MAX Exclusive.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://remax-crm-remax-app.jzuuqr.easypanel.host/*",
    "https://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}

{
  "manifest_version": 3,
  "name": "REMAX Meeting Recorder",
  "description": "Graba reuniones de Google Meet automáticamente — sin bots, sin participantes extra.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "REMAX Meeting Recorder"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://meet.google.com/*"],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://remax-crm-remax-app.jzuuqr.easypanel.host/*"
  ]
}

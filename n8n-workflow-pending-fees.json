          }
        ]
      ]
    },
    "¿Enviar WhatsApp?": {
      "main": [
        [
          {
            "node": "Typing WhatsApp",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Typing WhatsApp": {
      "main": [
        [
          {
            "node": "Enviar WhatsApp Cuota",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Enviar WhatsApp Cuota": {
      "main": [
        [
          {
            "node": "Marcar Leído WA",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "America/Santiago",
    "callerPolicy": "workflowsFromSameOwner"
  },
  "meta": {

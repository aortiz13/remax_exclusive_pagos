# ============================================
# Supabase Self-Hosted - Variables de Entorno
# Copia este archivo como .env y completá los valores
# ============================================

# ── PostgreSQL ──────────────────────────────
POSTGRES_PASSWORD=CAMBIAR_ESTO_PASSWORD_SEGURO
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── JWT (generar con el script 01-generate-jwt-keys.sh) ──
JWT_SECRET=CAMBIAR_ESTO_JWT_SECRET
ANON_KEY=CAMBIAR_ESTO_ANON_KEY
SERVICE_ROLE_KEY=CAMBIAR_ESTO_SERVICE_KEY

# ── URLs del sitio ──────────────────────────
# Tu dominio donde corre la app
SITE_URL=https://app.remax-exclusive.cl
# URL pública de la API de Supabase (creá un subdominio)
API_EXTERNAL_URL=https://supabase.remax-exclusive.cl

# ── Studio Dashboard ────────────────────────
STUDIO_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CAMBIAR_ESTO_DASHBOARD_PASSWORD
STUDIO_DEFAULT_ORGANIZATION=Remax Exclusive
STUDIO_DEFAULT_PROJECT=remax-app

# ── Auth (GoTrue) ───────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_SIGN_INS=false
JWT_EXPIRY=3600
ADDITIONAL_REDIRECT_URLS=

# ── SMTP (para emails de auth) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_ADMIN_EMAIL=admin@remax-exclusive.cl

# ── Kong Gateway ────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ── Edge Functions ──────────────────────────
FUNCTIONS_VERIFY_JWT=false

# ── PostgREST ───────────────────────────────
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ── Secrets para Edge Functions ─────────────
# (estos son los secrets que usan tus edge functions actuales)
# Revisá los secrets en Supabase Dashboard > Edge Functions > Secrets
# y agregalos aquí para que estén disponibles en el self-hosted
